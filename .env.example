# ── SynthGPU Environment Variables ───────────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# Virtual VRAM budget (MB). Auto-calculated from RAM if empty.
# SYNTHGPU_VRAM_MB=1024

# ── BLAS / CPU Thread Tuning ────────────────────────────────────────────────
# SynthGPU's WarpScheduler manages its own parallelism (ThreadPoolExecutor).
# Set BLAS thread counts to 1 to avoid thread oversubscription on CPU.
OPENBLAS_NUM_THREADS=1
MKL_NUM_THREADS=1
BLAS_NUM_THREADS=1
OMP_NUM_THREADS=2
NUMEXPR_NUM_THREADS=2
VECLIB_MAXIMUM_THREADS=2
NPY_DISABLE_CPU_FEATURES=

# ── Ollama Integration ───────────────────────────────────────────────────────
# Maximum parallel requests / loaded models for Ollama backend
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=1

# Inside Docker, localhost means the container, not the host machine.
# Docker Desktop resolves host.docker.internal automatically; compose adds the
# equivalent host-gateway mapping for native Linux Docker.
# SYNTHGPU_OLLAMA_URL=http://host.docker.internal:11434
# SYNTHGPU_LMSTUDIO_URL=http://host.docker.internal:1234
# HP DL360 external Ollama endpoint shown in the Custom tab.
SYNTHGPU_CUSTOM_OLLAMA_URL=http://10.0.0.219:11434

# ── Frontend ─────────────────────────────────────────────────────────────────
# API URL for the React dashboard (used in dev mode; production serves from
# the same origin)
# VITE_API_URL=http://localhost:8000

# ── Docker ───────────────────────────────────────────────────────────────────
# Set automatically inside the container. Do not override manually.
# SYNTHGPU_DOCKER=1
# SYNTHGPU_ROOT=/opt/synthgpu
